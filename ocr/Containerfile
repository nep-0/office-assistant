FROM docker.io/library/python:3.12-slim

WORKDIR /app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
RUN apt-get update \
    && apt-get install -y --no-install-recommends libgl1 libglib2.0-0 libgomp1 \
    && rm -rf /var/lib/apt/lists/*
COPY ocr/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir --upgrade pip && pip install --no-cache-dir -r requirements.txt
RUN mkdir -p /opt/ocr-models \
    && PADDLE_PDX_CACHE_HOME=/opt/ocr-models \
       PADDLE_PDX_MODEL_SOURCE=bos \
       PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True \
       python -c "from paddleocr import PaddleOCR; PaddleOCR(text_detection_model_name='PP-OCRv5_mobile_det', text_recognition_model_name='en_PP-OCRv5_mobile_rec', device='cpu', use_doc_orientation_classify=False, use_doc_unwarping=False, use_textline_orientation=False)" \
    && rm -rf /root/.cache /root/.modelscope /root/.paddlex
ENV PADDLEOCR_DETECTION_MODEL_DIR=/opt/ocr-models/official_models/PP-OCRv5_mobile_det
ENV PADDLEOCR_RECOGNITION_MODEL_DIR=/opt/ocr-models/official_models/en_PP-OCRv5_mobile_rec
ENV PADDLE_PDX_CACHE_HOME=/tmp/paddlex
COPY ocr/server.py ./server.py
EXPOSE 8082
CMD ["python", "server.py"]
